# All connection settings (RPC URLs, bridge addresses, tokens API, locker account) have
# canonical public defaults baked in per `--network`, so the tool runs with NO env vars.
# Set a variable only to OVERRIDE a default (e.g. a private, higher-rate-limit RPC).
#
# The only env vars normally needed are the signer for live mode (--execute), below.

# ===================== NEAR RPC API key (recommended) =====================
# The public NEAR RPC rate-limits (429) under the call volume of a full run. Use a
# fastnear API key — it is sent as an `Authorization: Bearer` header.
# IMPORTANT: put the key HERE, not in NEAR_RPC_URL. A key in the URL query string
# (`?apiKey=...`) is corrupted by near_api's RPC client and fails with 401.
# NEAR_API_KEY=your_fastnear_api_key

# ===================== Live mode (--execute) =====================
# The signer account must already hold Role::TokenLockController (or Role::DAO) on the
# bridge contract. Required only when running with --execute.
# NEAR_SIGNER_ACCOUNT_ID=token-lock-controller.near
# NEAR_SIGNER_SECRET_KEY=ed25519:...

# ===================== Optional overrides =====================
# RPC endpoints (defaults are public nodes):
# NEAR_RPC_URL=
# ETH_RPC_URL=
# ARB_RPC_URL=
# BASE_RPC_URL=
# BNB_RPC_URL=
# POL_RPC_URL=
# HLEVM_RPC_URL=
# ABS_RPC_URL=
# SOLANA_RPC_URL=
# FOGO_RPC_URL=
# STRK_RPC_URL=
#
# Tokens API / locker account:
# TOKENS_API_URL=
# OMNI_BRIDGE_ACCOUNT_ID=
#
# Bridge custody addresses for the solvency pre-check (EVM/Starknet address, or SVM
# bridge program id). Defaults are the canonical factory addresses per network.
# ETH_BRIDGE_ADDRESS=
# ARB_BRIDGE_ADDRESS=
# BASE_BRIDGE_ADDRESS=
# BNB_BRIDGE_ADDRESS=
# POL_BRIDGE_ADDRESS=
# HLEVM_BRIDGE_ADDRESS=
# ABS_BRIDGE_ADDRESS=
# STRK_BRIDGE_ADDRESS=
# SOL_BRIDGE_PROGRAM=
# FOGO_BRIDGE_PROGRAM=     # no testnet default (Fogo bridge not deployed on testnet)
